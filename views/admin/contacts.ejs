<%- include('../partials/admin-head') %>
<%- include('../partials/admin-header') %>

<main class="admin-main" id="main-content">
  <% const joinExportQuery = new URLSearchParams({ q: subscribers.query || '', domain: subscribers.domain || '', sort: subscribers.sort || 'asc' }).toString(); %>
  <% const clearContactsQuery = new URLSearchParams({ subscriberQ: subscribers.query || '', subscriberDomain: subscribers.domain || '', subscriberSort: subscribers.sort || 'asc' }).toString(); %>
  <% const clearSubscribersQuery = new URLSearchParams({ q: filters.q || '', status: filters.status || '', package: filters.package || '', from: filters.from || '', to: filters.to || '', sort: filters.sort || 'newest', page: filters.page || '1' }).toString(); %>
  <section class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Contacts</h1>
      <p class="admin-page-copy">Manage contact requests and Join subscribers.</p>
    </div>
    <div class="admin-inline-actions">
      <a href="/admin/contacts/export.csv?<%= new URLSearchParams(filters).toString() %>" class="admin-secondary-button">Export CSV</a>
      <a href="/admin/contacts/subscribers.csv<%= joinExportQuery ? '?' + joinExportQuery : '' %>" class="admin-secondary-button">Export Join List</a>
      <a href="/admin" class="admin-secondary-button">Back to Overview</a>
    </div>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-head">
      <h2>Lead Snapshot</h2>
      <p class="admin-panel-meta">Combined active records: <strong><%= leadSnapshot.combined %></strong></p>
    </div>
    <div class="admin-mini-kpis">
      <article class="admin-mini-kpi">
        <span>Contact Requests</span>
        <strong><%= leadSnapshot.contactLeads %></strong>
      </article>
      <article class="admin-mini-kpi">
        <span>Join Subscribers</span>
        <strong><%= leadSnapshot.joinSubscribers %></strong>
      </article>
      <article class="admin-mini-kpi">
        <span>Total Leads</span>
        <strong><%= leadSnapshot.combined %></strong>
      </article>
    </div>
  </section>

  <% if (uiMessage) { %>
  <p class="admin-alert" role="status"><%= uiMessage %></p>
  <% } %>

  <section class="admin-panel">
    <div class="admin-panel-head">
      <h2>Join CuzzyCrew Subscribers</h2>
      <p class="admin-panel-meta"><%= subscribers.filteredTotal %> shown of <%= subscribers.total %></p>
    </div>

    <form class="admin-subscriber-tools admin-box-tools" method="GET" action="/admin/contacts" data-auto-submit="subscribers">
      <label class="admin-form-field">
        <span>Search Join Emails</span>
        <input type="search" name="subscriberQ" value="<%= subscribers.query %>" placeholder="name@example.com"/>
      </label>
      <label class="admin-form-field">
        <span>Domain Filter</span>
        <input type="text" name="subscriberDomain" value="<%= subscribers.domain %>" placeholder="gmail.com"/>
      </label>
      <label class="admin-form-field">
        <span>Sort</span>
        <select name="subscriberSort">
          <option value="asc" <%= subscribers.sort === 'asc' ? 'selected' : '' %>>A-Z</option>
          <option value="desc" <%= subscribers.sort === 'desc' ? 'selected' : '' %>>Z-A</option>
        </select>
      </label>
      <input type="hidden" name="q" value="<%= filters.q %>"/>
      <input type="hidden" name="status" value="<%= filters.status %>"/>
      <input type="hidden" name="package" value="<%= filters.package %>"/>
      <input type="hidden" name="from" value="<%= filters.from %>"/>
      <input type="hidden" name="to" value="<%= filters.to %>"/>
      <input type="hidden" name="sort" value="<%= filters.sort %>"/>
      <input type="hidden" name="page" value="<%= filters.page %>"/>
      <div class="admin-inline-actions">
        <% if (subscribers.query || subscribers.domain || subscribers.sort === 'desc') { %>
        <a href="/admin/contacts?<%= clearSubscribersQuery %>" class="admin-secondary-button">Clear Join Filters</a>
        <% } %>
      </div>
      <noscript>
        <button type="submit" class="admin-secondary-button">Apply Join Filters</button>
      </noscript>
    </form>

    <% if (!subscribers.items.length) { %>
    <p class="admin-empty">No subscriber emails match this filter.</p>
    <% } else { %>
    <div class="admin-table-wrap">
      <table class="admin-table admin-table-subscribers">
        <caption class="sr-only">Join CuzzyCrew subscriber emails</caption>
        <thead>
          <tr>
            <th scope="col" class="col-rank">#</th>
            <th scope="col">Email</th>
          </tr>
        </thead>
        <tbody>
          <% subscribers.items.forEach(function(email, index) { %>
          <tr>
            <td class="col-rank"><%= index + 1 %></td>
            <td><a href="mailto:<%= email %>"><%= email %></a></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% if (subscribers.truncated) { %>
    <p class="admin-subtle">Showing first <%= subscribers.items.length %> matches. Export Join List to download all filtered results.</p>
    <% } %>
    <% } %>
  </section>

  <section class="admin-panel">
    <% const contactsReturnTo = currentQuery ? '/admin/contacts?' + currentQuery : '/admin/contacts'; %>
    <div class="admin-panel-head">
      <h2>Inbox</h2>
      <p class="admin-panel-meta"><%= contacts.total %> results</p>
    </div>

    <form class="admin-filters admin-box-tools admin-contact-tools" method="GET" action="/admin/contacts" data-auto-submit="contacts">
      <div class="admin-contact-tools-grid">
        <label class="admin-form-field">
          <span>Search Contacts</span>
          <input type="search" name="q" value="<%= filters.q %>" placeholder="Brand, email, or message" data-admin-search/>
        </label>
        <label class="admin-form-field">
          <span>Status</span>
          <select name="status">
            <option value="">All</option>
            <% ['new','in_review','contacted','won','lost','spam','archived'].forEach(function(status) { %>
            <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status.replace('_', ' ') %></option>
            <% }); %>
          </select>
        </label>
        <label class="admin-form-field">
          <span>Sort</span>
          <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest first</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest first</option>
            <option value="status" <%= filters.sort === 'status' ? 'selected' : '' %>>Status</option>
          </select>
        </label>
      </div>
      <details class="admin-advanced-filters">
        <summary>Advanced</summary>
        <div class="admin-advanced-grid">
          <label class="admin-form-field">
            <span>Package</span>
            <input type="text" name="package" value="<%= filters.package %>" placeholder="Custom or named package"/>
          </label>
          <label class="admin-form-field">
            <span>From</span>
            <input type="date" name="from" value="<%= filters.from %>"/>
          </label>
          <label class="admin-form-field">
            <span>To</span>
            <input type="date" name="to" value="<%= filters.to %>"/>
          </label>
        </div>
      </details>
      <input type="hidden" name="subscriberQ" value="<%= subscribers.query %>"/>
      <input type="hidden" name="subscriberDomain" value="<%= subscribers.domain %>"/>
      <input type="hidden" name="subscriberSort" value="<%= subscribers.sort %>"/>
      <div class="admin-filter-meta admin-filter-meta-contacts">
        <p class="admin-subtle admin-live-note" data-live-note>Live filter enabled.</p>
        <div class="admin-inline-actions">
          <a href="/admin/contacts<%= clearContactsQuery ? '?' + clearContactsQuery : '' %>" class="admin-secondary-button">Clear Contact Filters</a>
        </div>
      </div>
      <noscript>
        <button type="submit" class="admin-primary-button">Apply Contact Filters</button>
      </noscript>
    </form>

    <% if (!contacts.items.length) { %>
    <p class="admin-empty">No contact requests match these filters.</p>
    <% } else { %>
    <form method="POST" action="/admin/contacts/bulk" class="admin-bulk-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
      <input type="hidden" name="returnTo" value="<%= contactsReturnTo %>"/>
      <div class="admin-bulk-bar admin-bulk-bar-compact">
        <label class="admin-inline-field">
          <span>Bulk status</span>
          <select name="status">
            <% ['new','in_review','contacted','won','lost','spam','archived'].forEach(function(status) { %>
            <option value="<%= status %>"><%= status.replace('_', ' ') %></option>
            <% }); %>
          </select>
        </label>
        <span class="admin-selected-chip">Selected: <strong data-selected-count>0</strong></span>
        <button type="submit" class="admin-secondary-button">Update Selected</button>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table admin-table-contacts">
          <caption class="sr-only">Contact requests table</caption>
          <thead>
            <tr>
              <th scope="col" class="col-select"><input type="checkbox" aria-label="Select all contacts" data-select-all/></th>
              <th scope="col" class="col-contact">Contact</th>
              <th scope="col" class="col-status" aria-sort="<%= filters.sort === 'status' ? 'ascending' : 'none' %>">Status</th>
              <th scope="col" class="col-package">Package</th>
              <th scope="col" class="col-location">Location</th>
              <th scope="col" class="col-created" aria-sort="<%= filters.sort === 'newest' ? 'descending' : (filters.sort === 'oldest' ? 'ascending' : 'none') %>">Created</th>
            </tr>
          </thead>
          <tbody>
            <% contacts.items.forEach(function(contact) { %>
            <tr class="admin-inbox-row" data-row-open="/admin/contacts/<%= contact.id %>?from=<%= encodeURIComponent(contactsReturnTo) %>" tabindex="0" aria-label="Open details for <%= contact.brand %>">
              <td class="col-select"><input type="checkbox" name="contactIds" value="<%= contact.id %>" data-contact-select data-no-row-open aria-label="Select contact <%= contact.brand %>"/></td>
              <td class="col-contact">
                <a class="admin-contact-link" href="/admin/contacts/<%= contact.id %>?from=<%= encodeURIComponent(contactsReturnTo) %>" data-no-row-open>
                  <div class="admin-contact-main">
                    <strong><%= contact.brand %></strong>
                    <span><%= contact.email %></span>
                  </div>
                  <span class="admin-open-hint" aria-hidden="true">Details &rarr;</span>
                </a>
              </td>
              <td class="col-status"><span class="admin-status admin-status-<%= contact.status %>"><%= contact.status.replace('_', ' ') %></span></td>
              <td class="col-package"><%= contact.packageInterest || 'Custom' %></td>
              <td class="col-location"><%= contact.ipMetadata?.country || 'Unknown' %></td>
              <td class="col-created"><%= contact.createdAt.slice(0, 10) %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </form>

    <div class="admin-pagination" role="navigation" aria-label="Contacts pagination">
      <span>Page <%= contacts.page %> of <%= contacts.totalPages %></span>
      <div class="admin-inline-actions">
        <% if (contacts.page > 1) { %>
        <a href="?<%= new URLSearchParams({ ...filters, page: contacts.page - 1 }).toString() %>">Previous</a>
        <% } %>
        <% if (contacts.page < contacts.totalPages) { %>
        <a href="?<%= new URLSearchParams({ ...filters, page: contacts.page + 1 }).toString() %>">Next</a>
        <% } %>
      </div>
    </div>
    <% } %>
  </section>
</main>

<%- include('../partials/admin-foot') %>
